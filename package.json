{
  "name": "ebay-automation",
  "version": "1.0.0",
  "description": "eBay Automation Studio - Electron app with Playwright CDP for dedicated Chrome bot and DeepSeek-powered descriptions.",
  "main": "main.js",
  "scripts": {
    "start": "node scripts/start-electron.js",
    "build": "electron-builder --win",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "dotenv": "^17.4.2",
    "jimp": "^0.22.12",
    "playwright": "^1.60.0",
    "sharp": "^0.34.4"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.2"
  },
  "build": {
    "appId": "com.yoshstudios.ebaymarketplace",
    "productName": "eBay Automation",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "**/*",
      "!dist/**/*"
    ]
  }
}